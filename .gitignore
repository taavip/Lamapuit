Data/

# Data files (too large for git)
*.tif
*.tiff
*.laz
*.las
*.gpkg
*.geojson
!configs/*.yaml

# But include specific small examples in examples/data/
!examples/data/sample_chm_tile.tif
!examples/data/lamapuit_labels.gpkg
!examples/data/README.md


# Model weights — large trained models excluded, small base weights committed
*.pt
*.pth
*.onnx
# Allow base YOLO pre-trained weights (<50MB)
!yolo11n-seg.pt
!yolo11s-seg.pt
!yolo11m-seg.pt
!yolo26n.pt

# But include model registry and metadata
!models/MODEL_REGISTRY.md
!models/releases/*.yaml
!models/releases/*.md

# Logs and temp files
*.log
*.txt
!README*.md
!requirements.txt

# Build and test artifacts
htmlcov/
.pytest_cache/
.ruff_cache/
.coverage
postgres-data/
*.tar.gz
*.tar

# Temp experiment workspaces
*_tmp/
kpconv_tmp/
myria3d_tmp/
openpcseg_tmp/
randla_tmp/

# Unrelated exports
export_coco-instance_*.json

# OS
.DS_Store
Thumbs.db

# Temporary/experimental scripts at root
# Keep only src/ package
/*.py
!/setup.py

